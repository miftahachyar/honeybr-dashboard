rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Ruang kerja pembukuan Honeybr.
    // Default: hanya pengguna yang sudah login (termasuk Anonymous) yang boleh baca/tulis.
    match /workspaces/{id} {
      allow read, write: if request.auth != null;
    }

    // Tolak semua akses lain.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

/*
  CATATAN KEAMANAN
  ----------------
  Aturan di atas mengizinkan SIAPA SAJA yang membuka aplikasi (lewat Anonymous
  Auth) untuk membaca & menulis dokumen workspace. Ini cukup untuk alat internal
  yang link-nya hanya Anda bagikan ke owner.

  Ingin lebih ketat? Pakai login Email/Password lalu batasi ke email tertentu:

  match /workspaces/{id} {
    allow read, write: if request.auth != null &&
      request.auth.token.email in [
        'akuntan@contoh.com',
        'owner.honeybr@contoh.com'
      ];
  }

  (Aktifkan provider Email/Password di Authentication, dan ganti kode login di
  index.html dari signInAnonymously menjadi signInWithEmailAndPassword.)
*/
